generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  USER
}

enum JobStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ReminderStatus {
  OPEN
  COMPLETED
}

enum JobAttachmentKind {
  REFERENCE
  WORK
  BEFORE
  AFTER
}

enum JobEntryType {
  NOTE
  STATUS_CHANGE
  COMPLETION_REPORT
}

enum NotificationType {
  JOB_CREATED
  JOB_CLAIMED
  JOB_COMPLETED
  JOB_HIDDEN
  JOB_REOPENED
  REMINDER_COMPLETED
  USER_STATUS_CHANGED
}

model User {
  id                String          @id @default(cuid())
  name              String?
  email             String          @unique
  emailVerified     DateTime?
  image             String?
  role              Role            @default(USER)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  accounts          Account[]
  sessions          Session[]
  jobsCreated       Job[]           @relation("JobCreator")
  jobsAssigned      Job[]           @relation("JobAssignee")
  remindersCreated  Reminder[]      @relation("ReminderCreator")
  remindersDone     Reminder[]      @relation("ReminderCompleter")
  uploads           JobAttachment[] @relation("AttachmentUploader")
  entries           JobEntry[]      @relation("EntryAuthor")
  notifications     Notification[]
}

model Job {
  id              String          @id @default(cuid())
  title           String
  description     String
  address         String
  area            String?
  scheduledDate   DateTime
  technicianPhones String[]       @default([])
  status          JobStatus       @default(OPEN)
  creatorId       String
  assigneeId      String?
  notes           String?
  customerName    String          @default("Helsingin kaupunki")
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  completedAt     DateTime?
  hiddenAt        DateTime?
  creator         User            @relation("JobCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  assignee        User?           @relation("JobAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  attachments     JobAttachment[]
  entries         JobEntry[]
  notifications   Notification[]

  @@index([status, scheduledDate])
  @@index([assigneeId])
  @@index([creatorId])
  @@index([hiddenAt])
}

model Reminder {
  id            String         @id @default(cuid())
  title         String
  description   String?
  dueDate       DateTime
  status        ReminderStatus @default(OPEN)
  createdById   String
  completedById String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  completedAt   DateTime?
  createdBy     User           @relation("ReminderCreator", fields: [createdById], references: [id], onDelete: Cascade)
  completedBy   User?          @relation("ReminderCompleter", fields: [completedById], references: [id], onDelete: SetNull)

  @@index([status, dueDate])
  @@index([createdById])
}

model JobAttachment {
  id           String            @id @default(cuid())
  jobId         String
  kind         JobAttachmentKind
  storageKey   String            @unique
  caption      String?
  uploadedById String
  createdAt    DateTime          @default(now())
  job          Job               @relation(fields: [jobId], references: [id], onDelete: Cascade)
  uploadedBy   User              @relation("AttachmentUploader", fields: [uploadedById], references: [id], onDelete: Cascade)

  @@index([jobId, kind])
}

model JobEntry {
  id        String       @id @default(cuid())
  jobId      String
  authorId   String
  type      JobEntryType
  message   String
  metadata  Json?
  createdAt DateTime     @default(now())
  job       Job          @relation(fields: [jobId], references: [id], onDelete: Cascade)
  author    User         @relation("EntryAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  userId     String
  jobId      String?
  type      NotificationType
  payload   Json?
  readAt    DateTime?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  job       Job?             @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
}
